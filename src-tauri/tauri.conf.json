{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "winsvc-manager",
  "version": "1.0.0",
  "identifier": "com.tauri.winsvc-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NSSM Service Manager v1.0.0",
        "width": 1000,
        "height": 700,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": ["resources/win32", "resources/win64"],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "languages": ["SimpChinese", "English"],
        "installMode": "both"
      }
    }
  },
  "plugins": {}
}
